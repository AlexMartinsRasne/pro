# Environment variables - Copy this file to .env.local and fill in your values

# Required: SendGrid email configuration for the contact form backend
SENDGRID_API_KEY=
CONTACT_EMAIL=falconxxx475@gmail.com
FROM_EMAIL=no-reply@yourdomain.com

# Optional: Use a public form endpoint instead of SendGrid.
# Example for Formspree: https://formspree.io/f/{your_form_id}
FORM_ENDPOINT=

# Optional: Email service provider values if you want to use a client-side email integration
NEXT_PUBLIC_EMAIL_SERVICE_ID=
NEXT_PUBLIC_EMAIL_TEMPLATE_ID=
NEXT_PUBLIC_EMAIL_PUBLIC_KEY=

# Optional: API base URL for client-side requests in development or staging
NEXT_PUBLIC_API_URL=http://localhost:3000

# Notes:
# - SENDGRID_API_KEY must be kept secret and should NOT be committed to source control.
# - CONTACT_EMAIL is the address that will receive contact form submissions.
# - FROM_EMAIL should be a verified sender in your SendGrid account.
